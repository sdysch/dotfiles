#!/usr/bin/env python3
"""Waybar weather module backed by wttr.in.

Env vars:
    WEATHER_CACHE_TTL - seconds before refetching (default: 3600)
"""

import json
import os
import time
import urllib.error
import urllib.request

CACHE_DIR = os.environ.get("XDG_CACHE_HOME", os.path.expanduser("~/.cache"))
CACHE_FILE = os.path.join(CACHE_DIR, "weatherreport.json")

LOCATION = ""  # empty = wttr.in auto-detects via IP; set e.g. "London" to pin it
UNITS = "metric"  # "metric" or "imperial"
CACHE_TTL = int(os.environ.get("WEATHER_CACHE_TTL", "3600"))
REQUEST_TIMEOUT = 5

LABELS = [
    ("Morning", 600),
    ("Noon", 1200),
    ("Evening", 1800),
    ("Night", 0),
]

# condition keyword -> (emoji, waybar css class)
CONDITION_MAP = [
    (("sunny", "clear"), "☀️", "clear"),
    (("thunder", "storm"), "⛈", "storm"),
    (("snow", "sleet"), "❄️", "snow"),
    (("rain", "drizzle", "shower"), "🌧", "rain"),
    (("fog", "mist", "haze"), "🌫", "fog"),
    (("cloud", "overcast"), "☁️", "cloudy"),
]


def cond_lookup(cond):
    cond = cond.lower()
    for keywords, emoji, css_class in CONDITION_MAP:
        if any(k in cond for k in keywords):
            return emoji, css_class
    return "🌤", "default"


def fetch_weather():
    url = f"https://wttr.in/{LOCATION}?format=j1"
    if UNITS == "imperial":
        url += "&u"
    req = urllib.request.Request(url, headers={"User-Agent": "curl/8.0"})
    with urllib.request.urlopen(req, timeout=REQUEST_TIMEOUT) as resp:
        return json.loads(resp.read().decode())


def temp_key(units):
    return "temp_F" if units == "imperial" else "temp_C"


def hourly_temp_key(units):
    return "tempF" if units == "imperial" else "tempC"


def unit_suffix(units):
    return "°F" if units == "imperial" else "°C"


def pick_hour(hourly, target_time):
    for h in hourly:
        if int(h["time"]) == target_time:
            return h
    return None


def build_output(weather):
    current = weather["current_condition"][0]
    emoji, css_class = cond_lookup(current["weatherDesc"][0]["value"])
    text = f"{emoji} {current[temp_key(UNITS)]}{unit_suffix(UNITS)}"

    tooltip_lines = []
    for day in weather["weather"]:
        tooltip_lines.append(day["date"])
        for label, t in LABELS:
            hour = pick_hour(day["hourly"], t)
            if not hour:
                continue
            h_emoji, _ = cond_lookup(hour["weatherDesc"][0]["value"])
            temp = hour[hourly_temp_key(UNITS)]
            tooltip_lines.append(f"{h_emoji} {label}: {temp}{unit_suffix(UNITS)}")
        tooltip_lines.append("")
    tooltip = "\n".join(tooltip_lines).rstrip()

    return {
        "text": text,
        "tooltip": tooltip,
        "class": css_class,
        "fetched_at": int(time.time()),
    }


def read_cache():
    try:
        with open(CACHE_FILE) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError, ValueError):
        return None


def write_cache(data):
    os.makedirs(CACHE_DIR, exist_ok=True)
    tmp_path = CACHE_FILE + ".tmp"
    with open(tmp_path, "w") as f:
        json.dump(data, f)
    os.replace(tmp_path, CACHE_FILE)  # atomic


def cache_is_fresh(cached):
    return cached is not None and (time.time() - cached["fetched_at"]) < CACHE_TTL


def stale_fallback(cached, error_note):
    if cached is None:
        return {"text": "N/A", "tooltip": error_note, "class": "error"}
    age_min = int((time.time() - cached["fetched_at"]) / 60)
    return {
        "text": cached["text"],
        "tooltip": f"{cached['tooltip']}\n\n({error_note}, showing data from {age_min}m ago)",
        "class": cached.get("class", "default"),
    }


def main():
    cached = read_cache()

    if cache_is_fresh(cached):
        output = cached
    else:
        try:
            weather = fetch_weather()
            output = build_output(weather)
            write_cache(output)
        except urllib.error.URLError:
            output = stale_fallback(cached, "network error")
        except (KeyError, IndexError, ValueError, TypeError):
            output = stale_fallback(cached, "bad response from wttr.in")

    print(json.dumps({k: v for k, v in output.items() if k != "fetched_at"}))


if __name__ == "__main__":
    main()
