{
	"$schema": "https://opencode.ai/config.json",
	"theme": "nord",
	"permission": {
		"bash": {
			"*": "ask",
			"npm *": "allow",
			"rm *": "deny",
			"grep *": "allow",
			"git status*": "allow",
			"git diff*": "allow",
			"git log*": "allow",
			"git show*": "allow",
			"git push*": "deny"
		}
	}
}
